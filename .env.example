# YOINK.GG — Environment Configuration
#
# ═══════════════════════════════════════════════════════════════════════════════
# SOLANA
# ═══════════════════════════════════════════════════════════════════════════════
#
# Network for wallet connection + balance reads. Defaults to devnet.
# SAFETY: keep this on devnet. Do NOT point gameplay at mainnet-beta until the
# on-chain program (solana/programs/kings-bag) is deployed AND audited.
# Options: devnet | testnet | mainnet-beta
VITE_SOLANA_NETWORK=devnet

# Optional custom RPC endpoint (e.g. Helius / QuickNode). Falls back to the
# public cluster RPC if unset. A dedicated RPC is strongly recommended.
# VITE_SOLANA_RPC=https://api.devnet.solana.com

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE (server-authoritative backend)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Set VITE_SUPABASE_ENABLED=true to switch from client-side simulation to the
# Supabase-backed server-authoritative system. When false (default), the app
# runs entirely on the local sim (localStorage + bot vaults).
VITE_SUPABASE_ENABLED=false

# Your Supabase project URL (from Project Settings → API)
# VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (safe to expose in client code)
# VITE_SUPABASE_ANON_KEY=eyJ...

# ═══════════════════════════════════════════════════════════════════════════════
# TELEGRAM MINI APP
# ═══════════════════════════════════════════════════════════════════════════════
#
# Set VITE_TELEGRAM_ENABLED=true when deploying as a Telegram Mini App.
# This enables TG-native haptics, sharing, back button, and deep link referrals.
# The app auto-detects whether it's inside Telegram's WebView at runtime.
VITE_TELEGRAM_ENABLED=false

# Bot username (used for share links). Set after creating your bot via @BotFather.
# VITE_TELEGRAM_BOT_USERNAME=YoinkBot

# YOINK.GG — Solana wallet config
#
# Network for wallet connection + balance reads. Defaults to devnet.
# SAFETY: keep this on devnet. Do NOT point gameplay at mainnet-beta until the
# on-chain program (solana/programs/kings-bag) is deployed AND audited.
# Options: devnet | testnet | mainnet-beta
VITE_SOLANA_NETWORK=devnet

# Optional custom RPC endpoint (e.g. Helius / QuickNode). Falls back to the
# public cluster RPC if unset. A dedicated RPC is strongly recommended.
# VITE_SOLANA_RPC=https://api.devnet.solana.com
